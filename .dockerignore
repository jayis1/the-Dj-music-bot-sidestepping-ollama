# ── Secrets — never bake into image ──────────────────────────────────────
.env
.env.*
!.env.example

# ── Git ──────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github

# ── Python cache ─────────────────────────────────────────────────────────
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
dist/
build/
venv
.venv

# ── Logs ──────────────────────────────────────────────────────────────────
bot_activity.log
*.log

# ── Runtime data (mounted as volumes) ────────────────────────────────────
yt_dlp_cache/

# ── Dev tools ────────────────────────────────────────────────────────────
.ruff_cache
.ruff.toml
ruff.toml
tests/
pytest.ini
.pytest_cache

# ── IDE ──────────────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
*~

# ── Docs (not needed in image) ──────────────────────────────────────────
README.md
GUIDE.md
LICENSE
CHANGELOG.md

# ── OS files ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker files (not needed inside the image) ───────────────────────────
docker-compose*.yml
Dockerfile
.dockerignore

# ── MOSS TTS server (built separately as its own image) ─────────────────
moss-tts-server/

# ── Shadow Controller (separate repo, not part of bot image) ────────────────
shadow_controller/

# ── Browser extension (not needed in container) ──────────────────────────
extension/

# ── Temporary/persistent data (should be mounted as volumes) ──────────────
youtube_cookie.txt
*.tmp
*.bak