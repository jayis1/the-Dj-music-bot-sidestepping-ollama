# Discord Bot Configuration
# Copy from .env.example and fill in your details.

# Your Discord bot's authentication token.
DISCORD_TOKEN=

# Your YouTube Data API v3 key.
YOUTUBE_API_KEY=

# (Optional) The ID of the Discord channel where the bot should send logs.
LOG_CHANNEL_ID=

# The name of the radio station for the DJ bot.
STATION_NAME=MBot

# (Optional) Auto-DJ source - YouTube playlist URL or "preset:Name"
AUTODJ_SOURCE=

# (Optional) Discord channel ID for now-playing embed.
NOWPLAYING_CHANNEL_ID=

# Web Dashboard Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Password to access the Mission Control web dashboard.
WEB_PASSWORD=

# ── TTS Engine ──────────────────────────────────────────────────────────
# "edge-tts" = Microsoft Edge TTS (default), "local" = VibeVoice-Realtime
TTS_MODE=edge-tts

# Local TTS server URL (only used when TTS_MODE=local)
# Start VibeVoice: python demo/vibevoice_realtime_demo.py --model_path microsoft/VibeVoice-Realtime-0.5B
LOCAL_TTS_URL=http://localhost:3000

# ── AI Side Host (Ollama) ──────────────────────────────────────────────
OLLAMA_DJ_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_DJ_CHANCE=0.25
OLLAMA_DJ_VOICE=en-US-GuyNeural
OLLAMA_DJ_TIMEOUT=15