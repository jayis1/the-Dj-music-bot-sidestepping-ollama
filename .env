# Discord Bot Configuration
# Copy from .env.example and fill in your details.

# Your Discord bot's authentication token.
DISCORD_TOKEN=

# Your YouTube Data API v3 key.
YOUTUBE_API_KEY=

# (Optional) The ID of the Discord channel where the bot should send logs.
LOG_CHANNEL_ID=

# The name of the radio station for the DJ bot.
STATION_NAME=MBot

# (Optional) Auto-DJ source - YouTube playlist URL or "preset:Name"
AUTODJ_SOURCE=

# (Optional) Discord channel ID for now-playing embed.
NOWPLAYING_CHANNEL_ID=

# Web Dashboard Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8081

# Password to access the Mission Control web dashboard.
WEB_PASSWORD=

# Reverse Proxy Support (Nginx Proxy Manager, Caddy, Traefik, Cloudflare Tunnel, etc.)
# When enabled, Flask's ProxyFix middleware is applied so the dashboard correctly
# respects X-Forwarded-* headers. Fixes HTTPS redirects, real client IPs, and URL generation.
REVERSE_PROXY=false

# Number of trusted reverse proxy hops (only used when REVERSE_PROXY=true).
# Most setups have 1 (Nginx Proxy Manager → Bot). Set to 2 for double-proxy setups.
TRUSTED_PROXY_COUNT=1

# ── TTS Engine ──────────────────────────────────────────────────────────
# "moss" = MOSS-TTS-Nano server (default, local CPU/GPU), "vibevoice" = VibeVoice-Realtime server, "edge-tts" = Microsoft cloud
TTS_MODE=moss

# MOSS-TTS-Nano server URL (only used when TTS_MODE=moss)
# Start with: moss-tts-nano serve --port 18083
MOSS_TTS_URL=http://172.16.1.125:18083

# Default MOSS voice — name of a .wav prompt audio file in assets/moss_voices/ (without extension)
# Built-in voices: en_warm_female, en_news_male
MOSS_VOICE=en_warm_female

# VibeVoice server URL (only used when TTS_MODE=vibevoice)
# Start VibeVoice: python demo/vibevoice_realtime_demo.py --model_path microsoft/VibeVoice-Realtime-0.5B
VIBEVOICE_TTS_URL=http://localhost:3000

# ── AI Side Host (Ollama) ──────────────────────────────────────────────
OLLAMA_DJ_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_DJ_CHANCE=0.25
OLLAMA_DJ_VOICE=en_news_male
OLLAMA_DJ_TIMEOUT=15

# ── yt-dlp Cookie Auth ──────────────────────────────────────────────────
# YouTube requires cookies to avoid "Sign in to confirm you're not a bot" errors.
# Option 1: Use cookies from an installed browser (chrome, firefox, brave, edge, etc.)
# Option 2: Use a Netscape-format cookie file exported from your browser
# On headless servers, Firefox is easiest (Chrome needs keyring/secretstorage).
# Can also be set at runtime: ?ytcookies browser:firefox
YTDDL_COOKIES_FROM_BROWSER=
YTDDL_COOKIEFILE=youtube_cookie.txt

# ── YouTube Live Streaming ────────────────────────────────────────────
# Stream the bot's audio 24/7 to a YouTube Live event via RTMP.
# Get your stream key from YouTube Studio → Go Live → Stream Key.
# The bot streams audio + a static image card showing song titles.
# Between songs, a "waiting for next track" card is shown.
# Can also be started at runtime: ?golive or Mission Control → Radio → Go Live
# Set YOUTUBE_STREAM_ENABLED=true to auto-start on bot boot.
# Or leave it false and start manually when you want to go live.
YOUTUBE_STREAM_ENABLED=false
YOUTUBE_STREAM_KEY=
YOUTUBE_STREAM_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_STREAM_BACKUP_URL=rtmp://b.rtmp.youtube.com/live2?backup=1

# Optional: Path to a custom image for the stream video card (1280x720 recommended).
# If not set, the bot uses assets/logo.png or generates a black frame.
YOUTUBE_STREAM_IMAGE=

# Optional: Path to an animated GIF overlay for the stream video card.
# The GIF plays on top of the stream card, adding visual energy.
# Falls back to assets/giphy.gif if not set.
# Set to "" to disable the GIF overlay.
YOUTUBE_STREAM_GIF=