# ══════════════════════════════════════════════════════════════════════
# LIGHTWEIGHT DISCORD DJ BOT — Scaled-down .env for Discord-only mode
# ══════════════════════════════════════════════════════════════════════
# Use this when you just want a Discord music bot with DJ voice.
# No YouTube Live streaming, no MOSS TTS server, no Ollama AI host.
# 
# Copy to .env:  cp .env.discord .env
# Then fill in your DISCORD_TOKEN and you're good to go.
# ══════════════════════════════════════════════════════════════════════

# ── Required ────────────────────────────────────────────────────────
# Your Discord bot token (REQUIRED)
DISCORD_TOKEN=your_discord_bot_token

# YouTube Data API v3 key — needed for ?search and keyword-based ?play
YOUTUBE_API_KEY=

# ── Station Identity ────────────────────────────────────────────────
STATION_NAME=MBot

# ── Discord Channels (optional) ─────────────────────────────────────
# Channel ID for bot log messages (leave blank to disable)
LOG_CHANNEL_ID=
# Channel ID for the now-playing embed (leave blank to use command channel)
NOWPLAYING_CHANNEL_ID=

# ── Web Dashboard ──────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_PASSWORD=

# ── TTS Engine — Edge TTS (cloud, no server needed) ──────────────
# This is the lightest option — no local TTS server required.
# Just works out of the box. No Docker, no GPU, no extra services.
TTS_MODE=edge-tts

# Default DJ voice (edge-tts voice name)
# Use ?djvoices in Discord to see available voices
DJ_VOICE=en-US-AriaNeural

# ── AI Side Host — DISABLED (lightweight mode) ────────────────────
# No Ollama needed. Set to true if you want AI banter later.
OLLAMA_DJ_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_DJ_VOICE=en-US-GuyNeural
OLLAMA_DJ_CHANCE=0.25
OLLAMA_DJ_TIMEOUT=4

# ── YouTube Live Streaming — DISABLED ────────────────────────────
# Not needed for Discord-only mode.
YOUTUBE_STREAM_ENABLED=false
YOUTUBE_STREAM_KEY=
YOUTUBE_STREAM_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_STREAM_BACKUP_URL=rtmp://b.rtmp.youtube.com/live2?backup=1
YOUTUBE_STREAM_IMAGE=
YOUTUBE_STREAM_GIF=

# ── yt-dlp Cookie Auth (optional but recommended) ─────────────────
# YouTube blocks unauthenticated requests sometimes.
# Option 1: Browser cookies (easiest on desktop)
YTDDL_COOKIES_FROM_BROWSER=
# Option 2: Cookie file (works on headless servers)
YTDDL_COOKIEFILE=youtube_cookie.txt

# ── Auto-DJ (optional) ────────────────────────────────────────────
# YouTube playlist to refill the queue when it empties
AUTODJ_SOURCE=