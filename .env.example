# Discord Bot Configuration
# Copy this file to .env and fill in your details.

# Your Discord bot's authentication token.
# Find this on the Discord Developer Portal under your application's "Bot" page.
DISCORD_TOKEN=your_discord_bot_token

# Your YouTube Data API v3 key.
# Create a project on the Google Cloud Console, enable the YouTube Data API, and create an API key.
YOUTUBE_API_KEY=your_youtube_api_key

# (Optional) The ID of the Discord channel where the bot should send logs.
# Enable Developer Mode, right-click the channel and select "Copy Channel ID". Leave blank to disable.
LOG_CHANNEL_ID=

# The name of the radio station for the DJ bot.
# This appears in DJ station IDs ("You're listening to MBot Radio")
# and as the name in the web dashboard sidebar.
# Set this to your bot's name for consistency, or anything you like.
STATION_NAME=MBot

# The on-air personality name for the main DJ.
# This is the name the DJ introduces herself as ("This is Nova on MBot Radio").
# Pick something that sounds like a badass radio host — short, punchy, memorable.
DJ_NAME=Nova

#botowner is the id of the discord channel owner 
BOT_OWNER_ID=24

# (Optional) Auto-DJ source - YouTube playlist URL or "preset:Name"
# When the queue empties, Auto-DJ refills from this source.
# Leave blank to use recently-played history (shuffled replay).
AUTODJ_SOURCE=

# (Optional) Discord channel ID where the now-playing embed is sent.
# If set, all now-playing messages go to this one channel regardless
# of which channel the user typed the play command in.
# Enable Developer Mode in Discord, right-click the channel, "Copy Channel ID".
# Leave blank or 0 to send now-playing in the same channel as the command.
NOWPLAYING_CHANNEL_ID=

# Web Dashboard Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Password to access the Mission Control web dashboard.
# If left blank or unset, the dashboard is open to everyone (no login required).
WEB_PASSWORD=

# Hermes Agent API Key — machine-to-machine auth for the Shadow Controller.
# When set, /api/hermes/* endpoints are enabled and require this Bearer token.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Set the SAME key in the Shadow Controller's config.yaml or .env
# If blank/unset, Hermes API is disabled entirely.
HERMES_API_KEY=

# TTS Engine Configuration
# ──────────────────────────────────────────────────────────────────────────────
# The bot supports four TTS engines with a cascading fallback chain:
#
# "kokoro" (default) — Kokoro-FastAPI via its OpenAI-compatible API.
#   GPU-accelerated (NVIDIA CUDA), best quality voice synthesis. 82M params.
#   Local, fast (~35-100x realtime on GPU), OpenAI-compatible /v1/audio/speech.
#   See: https://github.com/remsky/Kokoro-FastAPI
#   Docker: docker compose up -d kokoro-tts
#   Voice names: af_bella, af_sky, am_adam, am_michael, bf_emma, bf_isabella, etc.
#   Prefixes: af=American female, am=American male, bf=British female, bm=British male
#   Voices can be combined: af_bella(2)+af_sky(1) for 67%/33% mix
#
# "moss" — MOSS-TTS-Nano via its FastAPI server.
#   CPU-friendly, voice cloning via .wav prompt files. 48 kHz stereo, multilingual.
#   See: https://github.com/OpenMOSS/MOSS-TTS-Nano
#   Or use docker-compose (includes the MOSS server automatically).
#   Voices are .wav prompt audio files in assets/moss_voices/
#
# "vibevoice" — VibeVoice-Realtime TTS server (https://github.com/microsoft/VibeVoice)
#   Lower latency (~300ms), runs on GPU/CPU in a separate process.
#   Voice names like: en-Carter_man, en-Journalist_woman, de-Anna_woman
#   (The legacy alias "local" also works and maps to vibevoice.)
#
# "edge-tts" — Microsoft Edge TTS voices. Free, no server needed, but cloud-dependent.
#   Voice names like: en-US-AriaNeural, en-US-GuyNeural, en-GB-SoniaNeural
#   Danish voices: da-DK-JeppeNeural (male), da-DK-SofieNeural (female)
#   Also used as automatic fallback when local engines fail.
#
# Fallback chain: kokoro → moss → edge-tts  (or moss → edge-tts, vibevoice → edge-tts)
TTS_MODE=kokoro

# Kokoro-FastAPI server URL (only used when TTS_MODE=kokoro).
# Docker: http://kokoro-tts:8880  |  Bare metal: http://localhost:8880
KOKORO_TTS_URL=http://localhost:8880

# MOSS-TTS-Nano server URL (used when TTS_MODE=moss or as fallback from kokoro).
# Docker: http://moss-tts:18083  |  Bare metal: http://localhost:18083
MOSS_TTS_URL=http://localhost:18083

# Default MOSS voice — name of a .wav prompt audio file in assets/moss_voices/
# (without the .wav extension). Built-in: en_warm_female, en_news_male,
# da_female (Danish female), da_male (Danish male)
# Add your own .wav files to assets/moss_voices/ to create new voices.
MOSS_VOICE=en_warm_female

# VibeVoice server URL (only used when TTS_MODE=vibevoice).
# Start VibeVoice with: python demo/vibevoice_realtime_demo.py --model_path microsoft/VibeVoice-Realtime-0.5B
VIBEVOICE_TTS_URL=http://localhost:3000

# ── AI Side Host (Ollama) ──────────────────────────────────────────────
# The AI side host is a second radio personality powered by a local LLM.
# It writes its own banter, shoutouts, and commentary — like a co-host
# who chimes in alongside the main DJ.
# Requires: Ollama running locally (https://ollama.com) with a pulled model.
#
# Docker: docker-compose.yml includes the Ollama container automatically.
#   The model is pulled on first start. Change OLLAMA_MODEL below to use
#   a different model. Popular choices:
#     - gemma3:4b       (4B params, fast, recommended for most hardware)
#     - llama3.2:3b     (3B params, very fast)
#     - phi3:mini       (3.8B params, fast)
#     - gemma4:latest   (latest Gemma, best quality, needs 8GB+ RAM)
#
# Standalone (no Docker): Install Ollama from https://ollama.com,
#   pull a model: ollama pull gemma3:4b
#   then set OLLAMA_HOST=http://localhost:11434
#
# Enable the AI side host. Set to "true" to activate.
OLLAMA_DJ_ENABLED=false

# Ollama server URL.
# Docker:          http://ollama:11434  (container hostname)
# Standalone:      http://localhost:11434
# Remote server:   http://your-server-ip:11434
OLLAMA_HOST=http://localhost:11434

# Ollama BASE model to use as the parent for the custom DJ model.
# The bot auto-creates a custom model (e.g. "mbot-sidehost") from this
# base model + a Modelfile that bakes in the DJ personality.
# Make sure you've pulled the base model: ollama pull <model_name>
# In Docker, the model is auto-pulled by the ollama-puller container.
#
# Recommended models (smaller = faster, larger = smarter):
#   gemma3:4b         — 4B params, best balance of speed & quality (recommended)
#   llama3.2:3b       — 3B params, very fast on CPU
#   phi3:mini         — 3.8B params, fast, good personality
#   gemma4:latest     — latest Gemma, best quality, needs 8GB+ RAM
OLLAMA_MODEL=gemma3:4b

# Custom Ollama model name. The bot creates this automatically from the
# base model. It persists in Ollama until you manually delete it.
# You can also chat with it directly: ollama run mbot-sidehost
# To recreate after a personality update: ollama rm mbot-sidehost
OLLAMA_CUSTOM_MODEL=mbot-sidehost

# How often the side host chimes in (0.0 to 1.0).
# 0.25 = ~25% chance after each template DJ line. 1.0 = always.
OLLAMA_DJ_CHANCE=0.25

# TTS voice for the AI side host (separate from the main DJ voice).
# This makes the two hosts sound like different people.
# Use ?djvoices in Discord to see available voices.
# The default depends on the active TTS engine:
#   moss:      en_news_male / da_male (male, contrasts with default female DJ)
#   vibevoice: en-Carter_man
#   edge-tts:  en-US-GuyNeural / da-DK-JeppeNeural (Danish male)
# Override with any valid voice name for your TTS engine.
OLLAMA_DJ_VOICE=am_adam

# Timeout in seconds for Ollama API calls. Side host is skipped if exceeded.
OLLAMA_DJ_TIMEOUT=4

# ── yt-dlp Cookie Authentication ──────────────────────────────────────
# YouTube increasingly requires cookies to avoid "Sign in to confirm
# you're not a bot" errors. There are two ways to provide cookies:
#
# Option 1: cookies from a browser (recommended for desktop setups)
# yt-dlp can extract cookies directly from an installed browser.
# Set this to the browser name: chrome, firefox, brave, edge, opera, vivaldi
# You must have logged into YouTube in that browser at least once.
# Can also specify a profile: e.g. "chrome:Profile 1" or "firefox:default"
# On headless Linux servers, Firefox is usually easiest (Chrome needs keyring).
# Or use `?ytcookies browser:chrome` in Discord to set this at runtime.
YTDDL_COOKIES_FROM_BROWSER=

# Option 2: Netscape-format cookie file (recommended for headless/Docker)
# Export YouTube cookies from your browser using an extension like
# "Get cookies.txt LOCALLY" (Chrome/Firefox) and save as youtube_cookie.txt
# in the bot's root directory.
# Or use `?ytcookies file` in Discord after placing the file.
YTDDL_COOKIEFILE=youtube_cookie.txt

# ── YouTube Live Streaming ──────────────────────────────────────────
# Stream the bot's audio to YouTube Live via RTMP or OBS Studio.
# The bot streams audio + a static image card showing song titles + DJ speaking.
# Between songs, a "waiting for next track" card is shown.
#
# Two modes available:
#   🪞 Mirror — mirrors Discord audio to YouTube (bot must be in a voice channel)
#   🎙️ Curated (Shadow DJ) — you pick the songs, DJ speaks between them
#
# Get your stream key from YouTube Studio → Go Live → Stream Key,
# or configure it on the OBS page in Mission Control.
# You can also start/stop the stream at runtime with:
#   Discord:  ?golive  /  ?stoplive  /  ?livestatus
#   Web:      Mission Control → Radio → YouTube Live → Go Live
# Set YOUTUBE_STREAM_ENABLED=true to enable the YouTube Live streaming feature
# (the Go Live button in Mission Control). The stream is started manually
# from the dashboard or via ?golive — not auto-started on boot.
YOUTUBE_STREAM_ENABLED=false
YOUTUBE_STREAM_KEY=

# YouTube provides TWO server URLs: a primary and a backup.
#   Primary:  rtmp://a.rtmp.youtube.com/live2
#   Backup:   rtmp://b.rtmp.youtube.com/live2?backup=1
# Use the backup URL as YOUTUBE_STREAM_BACKUP_URL so the bot can
# automatically fall back if the primary server has issues.
# YouTube also supports RTMPS (secure) — just change rtmp:// to rtmps://
# Example: YOUTUBE_STREAM_URL=rtmps://a.rtmp.youtube.com/live2
YOUTUBE_STREAM_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_STREAM_BACKUP_URL=rtmp://b.rtmp.youtube.com/live2?backup=1

# Optional: Path to a custom image for the stream video card (1280x720 recommended).
# If not set, the bot uses assets/logo.png or generates a black frame.
YOUTUBE_STREAM_IMAGE=

# Optional: Path to an animated GIF overlay for the stream video card.
# The GIF plays on top of the stream card, adding visual energy.
# Shows as an animated badge on the thumbnail during songs, and as a
# centered animation during waiting/DJ cards.
# Falls back to assets/giphy.gif if not set.
# Set to "" to disable the GIF overlay.
YOUTUBE_STREAM_GIF=

# Default playlist URL for YouTube Live curated (Shadow DJ) mode.
# When starting curated streaming from the web dashboard without specifying
# a playlist, this URL is used for initial queue filling.
# Can be a YouTube playlist URL or a search query.
# Example: https://youtube.com/playlist?list=PLxxxxxxx
YOUTUBE_STREAM_PLAYLIST=

# ── YouTube Live via OBS Studio ─────────────────────────────────────
# When OBS Studio is connected (via obs-websocket), YouTube Live streaming
# goes through OBS instead of a separate Chromium+FFmpeg pipeline.
# OBS handles the visual overlay (browser source) and streams to YouTube.
#
# The overlay URL used in OBS browser sources. Defaults to localhost for
# bare-metal, use http://bot:8080/overlay for Docker.
OBS_OVERLAY_URL=http://localhost:8080/overlay

# ── GPU Acceleration ────────────────────────────────────────────────────
#
# There are 3 GPU profiles — pick the one that matches your hardware:
#
#   CPU only (default):   docker compose up -d
#   AMD GPU:              docker compose --profile amd-gpu up -d
#   NVIDIA GPU:           docker compose --profile nvidia-gpu up -d
#
# ── AMD GPU Details ───────────────────────────────────────────────────────
#
# The amd-gpu profile passes /dev/kfd and /dev/dri to containers.
# Ollama uses the ROCm image for GPU inference. MOSS-TTS gets GPU access.
# The bot gets /dev/dri for VA-API hardware encoding (YouTube Live).
#
# ROCm 7.2 officially supports:
#   ✅ RX 9070/9060 series        (RDNA4, gfx1200/gfx1201)
#   ✅ RX 7900/7800/7700/7600     (RDNA3, gfx1100/1101/1102)
#   ✅ RX 6800/6700/6600          (RDNA2, gfx1030)
#   ✅ AMD Instinct MI300/MI250   (CDNA3/CDNA2, gfx942/gfx90a)
#   ✅ Radeon PRO W7900/W7800 etc. (RDNA3/2)
#
# Community-enabled (works but not official):
#   ⚠️  RX 5700/5600/5500        (RDNA1, gfx1010/1011/1012)
#
# Integrated/low-tier GPUs (gfx90c, gfx906, etc.):
#   ℹ️  VA-API encoding works, but ROCm/LLM inference falls back to CPU.
#       This is fine — Ollama and MOSS are fast on CPU.
#       Set HSA_OVERRIDE_GFX_VERSION only if Ollama fails to start.
#
# HSA_OVERRIDE_GFX_VERSION cheat sheet:
#   RDNA4  (RX 9070/9060):       not needed (native support)
#   RDNA3  (RX 7900/7800/7700):   not needed (native support)
#   RDNA2  (RX 6800/6700/6600):   10.3.0
#   RDNA1  (RX 5700/5600/5500):   10.1.0
#   Integrated (Ryzen APU):       leave empty (Ollama uses CPU)
#
# ── NVIDIA GPU Details ────────────────────────────────────────────────────
#
# Requires nvidia-container-toolkit installed on host.
# See: https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/install-guide.html
#
# ── VA-API Hardware Encoding (YouTube Live) ────────────────────────────────
#
# Set AMD_GPU_VAAPI=1 to use AMD GPU hardware encoding (h264_vaapi)
# for YouTube Live streaming. This dramatically reduces CPU usage.
# Works on virtually ALL AMD GPUs including integrated ones (gfx90c).
#
# When using --profile amd-gpu, this is set automatically.
# For standalone (non-Docker) use, set it manually:
#   AMD_GPU_VAAPI=1
#
# Check if your GPU supports VA-API:
#   vainfo  (install: sudo apt install vainfo)
#   ls -la /dev/dri/renderD128
#
# Leave unset or set to 0 for CPU-only encoding (libx264, works everywhere).
AMD_GPU_VAAPI=

# HSA_OVERRIDE_GFX_VERSION — only needed for older/unsupported AMD GPUs.
# Leave empty if your GPU is natively supported by ROCm 7.2 (RDNA3/4, CDNA2/3).
# Set to e.g. "10.3.0" for RDNA2 or "10.1.0" for RDNA1.
HSA_OVERRIDE_GFX_VERSION=

# ── OBS Studio Integration ─────────────────────────────────────────────
# Control OBS Studio from Mission Control via obs-websocket 5.x.
# Requires OBS Studio with WebSocket server enabled (bundled since OBS 28).
#
# Setup:
#   1. Install OBS Studio: https://obsproject.com
#   2. In OBS: Tools → WebSocket Server Settings → Enable
#   3. Set a password in OBS WebSocket settings
#   4. Set OBS_WS_PASSWORD below to match
#
# Once configured, open Mission Control → OBS Studio to control
# scenes, streaming, recording, sources, and more from the dashboard.
OBS_WS_ENABLED=true
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=

# OBS Auto Scene Switching — the bot automatically switches OBS scenes based
# on playback state. This makes the YouTube Live visual match the audio.
# Requires OBS_WS_ENABLED=true and OBS_WS_PASSWORD set.
# Set to "true" to enable auto scene switching.
OBS_AUTO_SCENES=false

# Scene names the bot will switch to. These must match your OBS scene
# collection exactly (case-sensitive). The default scene collection includes
# these scenes. Only change if you rename scenes in OBS.
OBS_SCENE_NOW_PLAYING=️ Now Playing
OBS_SCENE_DJ_SPEAKING=🎙️ DJ Speaking
OBS_SCENE_WAITING=⏳ Waiting
OBS_SCENE_OVERLAY=📺 Overlay Only

# OBS Overlay Mode — how the overlay is rendered in OBS:
#   "browser" — Full Mission Control overlay via browser_source (visualizer, album art, SFX)
#               REQUIRES obs-browser plugin (Flatpak OBS, Ubuntu PPA, Windows, macOS)
#   "native"  — OBS color + text sources (works everywhere, no visualizer)
#   "auto"    — Try browser first, fall back to native if obs-browser unavailable (DEFAULT)
OBS_OVERLAY_MODE=auto

# OBS Install Method — which OBS installation to use:
#   "true"   — OBS installed via Flatpak (includes obs-browser for visualizer)
#   "false"  — OBS installed via apt (no obs-browser)
#   "auto"   — Auto-detect (DEFAULT — start.sh checks for Flatpak OBS first)
# When Flatpak OBS is detected:
#   - Launch: flatpak run com.obsproject.Studio
#   - Config: ~/.var/app/com.obsproject.Studio/config/obs-studio/
#   - Headless: QT_QPA_PLATFORM=offscreen (no xvfb needed)
OBS_USE_FLATPAK=auto

# ── Radio Commercial Breaks ────────────────────────────────────────
# AI-generated "fake" radio commercials that play between songs for
# that authentic 24/7 radio feel. Uses Ollama for unique ad copy each
# time, with ~40 pre-written absurdist templates as fallback.
#
# Commercial breaks play BEFORE the DJ intro for the next song:
#   [Song A] → [Commercial] → [DJ: "Up next, Song B!"] → [Song B]

# Master switch for commercial breaks.
COMMERCIAL_ENABLED=true

# Probability of a commercial per eligible song transition.
# 0.15 = ~15% base chance, scales up over time (capped at 60%).
COMMERCIAL_CHANCE=0.15

# Minimum songs between commercial breaks (prevents ad overload).
COMMERCIAL_MIN_SONGS=3

# Maximum TTS duration in seconds (truncated at sentence boundary).
COMMERCIAL_MAX_DURATION=30

# Don't play commercials if the queue has fewer than N songs.
COMMERCIAL_MIN_QUEUE=2

# 3 rotating "announcer" voices so consecutive ads sound like different
# spokespersons. Comma-separated TTS voice names.
# Kokoro defaults: am_adam (American male), bf_emma (British female), bm_george (British male)
COMMERCIAL_VOICES=am_adam,bf_emma,bm_george

# ── Station Wars: Frequency Hijack ─────────────────────────────────
# Instead of a normal commercial, a transmission from another dimension/kosmos
# "bleeds" onto the frequency for ~15 seconds. The DJ then cuts back in with
# a recovery line. Same voices as commercials, but from another kosmos.
#
# Station Wars is checked BEFORE normal commercials. If a hijack triggers,
# it replaces the commercial break entirely.
#
# Flow: [Song A] → [Dimensional bleed] → [DJ: "We're back from the void!"] → [DJ intro] → [Song B]

# Master switch for Station Wars dimensional frequency hijacks.
RADIO_HIJACK_ENABLED=true

# Probability of a frequency hijack per eligible song transition.
# 0.05 = ~5% chance. Rare enough to never get old.
RADIO_HIJACK_CHANCE=0.05

# ── SilverBullet Knowledge Base ──────────────────────────────────
# The Hermes Agent documents station events (incidents, hijacks,
# commercials, tracks, stream health) to a SilverBullet PKM instance.
# This creates a queryable, hyperlinked station knowledge base.
# Set SILVERBULLET_ENABLED=true and provide your SilverBullet URL.
# No token needed if your SilverBullet has no auth configured.

# Enable auto-documentation to SilverBullet.
SILVERBULLET_ENABLED=false

# Base URL of your SilverBullet instance (no trailing slash).
SILVERBULLET_URL=https://silver.istealyourdomain.org

# Bearer token for SB_AUTH_TOKEN (leave blank if no auth).
SILVERBULLET_TOKEN=

# Page path prefix for all station docs.
SILVERBULLET_PREFIX=station
