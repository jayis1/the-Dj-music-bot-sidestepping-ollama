# Discord Bot Configuration
# Copy this file to .env and fill in your details.

# Your Discord bot's authentication token.
# Find this on the Discord Developer Portal under your application's "Bot" page.
DISCORD_TOKEN=your_discord_bot_token

# Your YouTube Data API v3 key.
# Create a project on the Google Cloud Console, enable the YouTube Data API, and create an API key.
YOUTUBE_API_KEY=your_youtube_api_key

# (Optional) The ID of the Discord channel where the bot should send logs.
# Enable Developer Mode, right-click the channel and select "Copy Channel ID". Leave blank to disable.
LOG_CHANNEL_ID=

# The name of the radio station for the DJ bot.
# This appears in DJ station IDs ("You're listening to MBot Radio")
# and as the name in the web dashboard sidebar.
# Set this to your bot's name for consistency, or anything you like.
STATION_NAME=MBot

#botowner is the id of the discord channel owner 
BOT_OWNER_ID=24

# (Optional) Auto-DJ source - YouTube playlist URL or "preset:Name"
# When the queue empties, Auto-DJ refills from this source.
# Leave blank to use recently-played history (shuffled replay).
AUTODJ_SOURCE=

# (Optional) Discord channel ID where the now-playing embed is sent.
# If set, all now-playing messages go to this one channel regardless
# of which channel the user typed the play command in.
# Enable Developer Mode in Discord, right-click the channel, "Copy Channel ID".
# Leave blank or 0 to send now-playing in the same channel as the command.
NOWPLAYING_CHANNEL_ID=

# Web Dashboard Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Password to access the Mission Control web dashboard.
# If left blank or unset, the dashboard is open to everyone (no login required).
WEB_PASSWORD=

# TTS Engine Configuration
# ──────────────────────────────────────────────────────────────────────────────
# The bot supports three TTS engines:
#
# "moss" (default) — MOSS-TTS-Nano via its FastAPI server.
#   Local, open-weight, 0.1B params, runs on CPU or GPU. Voice cloning via
#   prompt audio files. 48 kHz stereo, multilingual (20 languages).
#   Voices are .wav prompt audio files in assets/moss_voices/
#   Start with: moss-tts-nano serve --port 18083
#   Or use docker-compose (includes the MOSS server automatically).
#   See: https://github.com/OpenMOSS/MOSS-TTS-Nano
#
# "vibevoice" — VibeVoice-Realtime TTS server (https://github.com/microsoft/VibeVoice)
#   Lower latency (~300ms), runs on GPU/CPU in a separate process.
#   Voice names like: en-Carter_man, en-Journalist_woman, de-Anna_woman
#   Requires: VibeVoice server running (see docs for setup)
#   (The legacy alias "local" also works and maps to vibevoice.)
#
# "edge-tts" — Microsoft Edge TTS voices. Free, no server needed, but cloud-dependent.
#   Voice names like: en-US-AriaNeural, en-US-GuyNeural, en-GB-SoniaNeural
#   Requires: pip install edge-tts
#   Also used as automatic fallback when local engines fail.
#
# Fallback chain: moss → edge-tts  (or vibevoice → edge-tts)
TTS_MODE=moss

# MOSS-TTS-Nano server URL (only used when TTS_MODE=moss).
# Start with: moss-tts-nano serve --port 18083
# Or use docker-compose which starts the MOSS server automatically.
MOSS_TTS_URL=http://localhost:18083

# Default MOSS voice — name of a .wav prompt audio file in assets/moss_voices/
# (without the .wav extension). Built-in: en_warm_female, en_news_male
# Add your own .wav files to assets/moss_voices/ to create new voices.
MOSS_VOICE=en_warm_female

# VibeVoice server URL (only used when TTS_MODE=vibevoice).
# Start VibeVoice with: python demo/vibevoice_realtime_demo.py --model_path microsoft/VibeVoice-Realtime-0.5B
VIBEVOICE_TTS_URL=http://localhost:3000

# ── AI Side Host (Ollama) ──────────────────────────────────────────────
# The AI side host is a second radio personality powered by a local LLM.
# It writes its own banter, shoutouts, and commentary — like a co-host
# who chimes in alongside the main DJ.
# Requires: Ollama running locally (https://ollama.com) with a pulled model.
#
# Enable the AI side host. Set to "true" to activate.
OLLAMA_DJ_ENABLED=false

# Ollama server URL.
OLLAMA_HOST=http://localhost:11434

# Ollama BASE model to use as the parent for the custom DJ model.
# The bot auto-creates a custom model (e.g. "mbot-sidehost") from this
# base model + a Modelfile that bakes in the DJ personality.
# Make sure you've pulled the base model: ollama pull <model_name>
# Recommended: gemma4:latest, phi3:mini (3.8B, fast), llama3.2 (3B), gemma2:2b (2B)
OLLAMA_MODEL=gemma4:latest

# Custom Ollama model name. The bot creates this automatically from the
# base model. It persists in Ollama until you manually delete it.
# You can also chat with it directly: ollama run mbot-sidehost
# To recreate after a personality update: ollama rm mbot-sidehost
OLLAMA_CUSTOM_MODEL=mbot-sidehost

# How often the side host chimes in (0.0 to 1.0).
# 0.25 = ~25% chance after each template DJ line. 1.0 = always.
OLLAMA_DJ_CHANCE=0.25

# TTS voice for the AI side host (separate from the main DJ voice).
# This makes the two hosts sound like different people.
# Use ?djvoices in Discord to see available voices.
# The default depends on the active TTS engine:
#   moss:      en_news_male (male, contrasts with default female DJ)
#   vibevoice: en-Carter_man
#   edge-tts:  en-US-GuyNeural
# Override with any valid voice name for your TTS engine.
OLLAMA_DJ_VOICE=en_news_male

# Timeout in seconds for Ollama API calls. Side host is skipped if exceeded.
OLLAMA_DJ_TIMEOUT=4
