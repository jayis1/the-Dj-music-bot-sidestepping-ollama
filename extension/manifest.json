{
  "manifest_version": 3,
  "name": "MBot Cookie Bridge",
  "description": "One-click YouTube cookie bridge for your MBot Radio DJ. Keeps the music playing 24/7.",
  "version": "1.0.0",
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://*:*/*",
    "https://*:*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*:*/*", "https://*:*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}