# ──────────────────────────────────────────────────────────────────
# Shadow Controller — Environment Overrides
# ──────────────────────────────────────────────────────────────────
# These override config.yaml values. Useful for secrets you don't
# want in the yaml file. Copy to .env and fill in.
# ──────────────────────────────────────────────────────────────────

# DJ Bot Mission Control
BOT_API_URL=http://192.168.1.50:8080
GUILD_ID=YOUR_GUILD_ID

# ── Auth (pick one) ──────────────────────────────────────────────
# Option A: Hermes Agent API Key (preferred — no session/CSRF needed)
# Generate on the DJ bot server with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Then set HERMES_API_KEY in the DJ bot's .env too
HERMES_API_KEY=

# Option B: Mission Control web password (session auth fallback)
WEB_PASSWORD=

# Ollama (on this VM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=hermes3:8b

# Alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Discord Fan Request Watcher (DISABLED — leave blank if not using)
# You need a SEPARATE Discord bot token for this, not the DJ bot token
# Only fill these in if you want fan request watching
DISCORD_WATCHER_TOKEN=
FAN_REQUEST_CHANNEL_ID=

# YouTube Live stream URL
YOUTUBE_LIVE_URL=https://www.youtube.com/channel/YOUR_CHANNEL/live