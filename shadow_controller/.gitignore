# Shadow Controller .gitignore

# Config with secrets
config.yaml
.env

# Python
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# Playwright
.playwright/

# Logs
*.log
shadow_controller.log

# Firefox profile copy (runtime)
/tmp/

# OS files
.DS_Store
Thumbs.db

# Cookie files (sensitive!)
cookies.txt
youtube_cookies.txt
*.cookie.txt